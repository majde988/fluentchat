{
  "appId": "com.fluentchat.app",
  "appName": "FluentChat",
  "webDir": "../public",
  "server": {
    "androidScheme": "https"
  },
  "plugins": {
    "PushNotifications": {
      "presentationOptions": [
        "badge",
        "sound",
        "alert"
      ]
    },
    "LocalNotifications": {
      "smallIcon": "ic_stat_icon",
      "iconColor": "#0a84ff"
    }
  },
  "android": {
    "allowMixedContent": true,
    "backgroundColor": "#0a84ff"
  }
}
